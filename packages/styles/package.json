{
  "name": "@lite-app/styles",
  "type": "module",
  "exports": {
    ".": {
      "style": "./src/index.css"
    },
    "./css": {
      "style": "./src/index.css",
      "default": "./src/index.css"
    },
    "./components/*": {
      "types": "./src/components/*.ts",
      "import": "./src/components/*.ts",
      "default": "./src/components/*.ts"
    }
  },
  "dependencies": {
    "tailwind-merge": "catalog:",
    "tailwind-variants": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:"
  }
}
